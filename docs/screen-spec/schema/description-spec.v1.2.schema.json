{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ywal123456-collab/jskim/raw/main/docs/screen-spec/schema/description-spec.v1.2.schema.json",
  "title": "JSKim Screen Spec Description v1.2",
  "description": "spec/{projectName}/src/data に置く説明用 JSON（人向け）。v1.1 に excludedItems（設計対象から除外した収集項目と説明の退避）を追加した version。収集手順は含めない。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "screen", "itemOrder", "items", "excludedItems"],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.2"
    },
    "screen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "itemOrder": {
      "type": "array",
      "maxItems": 500,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "items": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/id"
      },
      "additionalProperties": {
        "$ref": "#/$defs/itemDescription"
      }
    },
    "excludedItems": {
      "type": "object",
      "description": "設計対象から除外した項目。key が itemId。実装 observation 自体は削除しない。",
      "propertyNames": {
        "$ref": "#/$defs/id"
      },
      "additionalProperties": {
        "$ref": "#/$defs/itemDescription"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 128
    },
    "itemDescription": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "description", "note"],
      "properties": {
        "name": {
          "type": "string",
          "description": "空文字を許可（draft / 再収集時の未記入）"
        },
        "type": {
          "type": "string",
          "description": "空文字を許可（draft / 再収集時の未記入）"
        },
        "description": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}
