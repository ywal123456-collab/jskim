{% extends "layouts/base.njk" %}
{% set currentSection = "wizard" %}
{% set currentStep = 3 %}
{% set breadcrumbs = [
  { label: "Portal", href: rootPath + "index.html" },
  { label: "申込sample", href: rootPath + "wizard/input.html" },
  { label: "完了" }
] %}

{% block title %}完了 - {{ site.name }}{% endblock %}

{% block pageCss %}
  <link rel="stylesheet" href="assets/css/wizard.css">
{% endblock %}

{% block content %}
<section class="page-intro">
  <h1>完了</h1>
  <p class="lead">
    画面遷移 sample の完了画面です。
  </p>
</section>

{% include "components/wizard-steps.njk" %}

<section class="complete-panel" aria-labelledby="wizard-complete-heading">
  <p class="complete-panel__mark" aria-hidden="true">OK</p>
  <h2 id="wizard-complete-heading">画面遷移が完了しました</h2>
  <p>
    この画面は静的 UI sample です。
    入力内容の送信および保存は行われていません。
  </p>
  <p>
    入力画面の内容は引き継がれておらず、API 通信も含まれていません。
  </p>
</section>

<section class="page-nav" aria-label="完了後の移動">
  <a class="button" href="input.html">最初から確認する</a>
  <a class="button button--secondary" href="../index.html">Portal へ戻る</a>
</section>
{% endblock %}
