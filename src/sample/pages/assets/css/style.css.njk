:root {
  --theme-color: {{ site.themeColor }};
  --surface-color: #ffffff;
  --text-color: #222222;
  --muted-color: #666666;
  --border-color: #dddddd;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  color: var(--text-color);
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  line-height: 1.7;
  background: #f6f6f6;
}

a {
  color: var(--theme-color);
}

.wrap {
  width: min(960px, calc(100% - 32px));
  margin: 0 auto;
}

.site-header,
.site-footer {
  background: var(--surface-color);
  border-bottom: 1px solid var(--border-color);
}

.site-footer {
  margin-top: 48px;
  border-top: 1px solid var(--border-color);
  border-bottom: 0;
}

.site-footer .wrap {
  padding: 20px 0;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 16px 0;
}

.brand,
.site-nav {
  display: flex;
  align-items: center;
  gap: 12px;
}

.brand {
  color: var(--theme-color);
  font-weight: 700;
  text-decoration: none;
}

.site-nav a {
  color: var(--muted-color);
  text-decoration: none;
}

.site-main {
  padding: 48px 0 0;
}

.hero,
.card,
.request-hero {
  padding: 32px;
  background: var(--surface-color);
  border: 1px solid var(--border-color);
  border-radius: 16px;
}

.hero h1,
.request-hero h1 {
  margin: 0 0 12px;
  font-size: clamp(2rem, 5vw, 3.5rem);
}

.eyebrow {
  margin: 0 0 8px;
  color: var(--theme-color);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
  margin-top: 24px;
}

code {
  padding: 0.1em 0.35em;
  background: #eeeeee;
  border-radius: 4px;
}
