{% extends "layouts/base.njk" %}

{% block title %}JSKim — Nunjucks 静的 HTML ビルド{% endblock %}
{% block description %}JSKim サンプル: 設定駆動の Nunjucks から静的 HTML へ{% endblock %}

{% block content %}
{% set frameworkName = "JSKim" %}
{% set version = "0.1.0" %}
{% set features = ["config", "render", "copy", "clean", "rootPath"] %}
{% set build = { command: "npm run build -- sample", output: "dist/sample" } %}
{% set status = "ready" %}

<section class="hero wrap">
  <h1>{{ frameworkName }}へようこそ</h1>
  <p class="lead">
    Nunjucks ソースを設定に従って静的 HTML にレンダリングする汎用ビルド環境です。
    バージョン <strong>{{ version }}</strong> のサンプルページです。
  </p>
</section>

<section class="wrap section" id="run">
  <h2>実行コマンド</h2>
  <p>プロジェクト名は <code>jskim.config.js</code> の <code>projects</code> キーと一致させてください。</p>
  <pre class="code"><code>{{ build.command }}</code></pre>
  <p>出力ディレクトリ: <code>{{ build.output }}</code></p>
</section>

<section class="wrap section" id="structure">
  <h2>基本ディレクトリ構成</h2>
  <pre class="code"><code>src/sample/
├─ pages/
│  └─ index.njk
├─ layouts/
│  └─ base.njk
├─ components/
│  ├─ head.njk
│  ├─ header.njk
│  └─ footer.njk
└─ assets/
   └─ css/
      └─ style.css</code></pre>
</section>

<section class="wrap section" id="config">
  <h2>ビルド設定（jskim.config.js）</h2>
  <p>
    ワークスペースルートの設定ファイルがビルドの基準です。
    <code>defaults</code> と <code>projects</code> をマージしてプロジェクトごとの出力を作ります。
  </p>
  <ul class="feature-list">
    {% for item in features %}
    <li>{{ item }}</li>
    {% endfor %}
  </ul>
</section>

<section class="wrap section" id="syntax">
  <h2>Nunjucks の基本構文 — ソース / レンダリング結果</h2>
  <p>以下の例は、このページで実際にレンダリングされた結果です。</p>

  <article class="demo">
    <h3>変数出力</h3>
    <div class="demo-grid">
      <div>
        <h4>ソース</h4>
        <pre class="code"><code>{% raw %}{{ frameworkName }}{% endraw %}</code></pre>
      </div>
      <div>
        <h4>結果</h4>
        <pre class="code result"><code>{{ frameworkName }}</code></pre>
      </div>
    </div>
  </article>

  <article class="demo">
    <h3>set</h3>
    <div class="demo-grid">
      <div>
        <h4>ソース</h4>
        <pre class="code"><code>{% raw %}{% set version = "0.1.0" %}
{{ version }}{% endraw %}</code></pre>
      </div>
      <div>
        <h4>結果</h4>
        <pre class="code result"><code>{{ version }}</code></pre>
      </div>
    </div>
  </article>

  <article class="demo">
    <h3>if / elif / else</h3>
    <div class="demo-grid">
      <div>
        <h4>ソース</h4>
        <pre class="code"><code>{% raw %}{% if status == "ready" %}
  ビルド準備完了
{% elif status == "pending" %}
  ビルド待機中
{% else %}
  不明な状態
{% endif %}{% endraw %}</code></pre>
      </div>
      <div>
        <h4>結果</h4>
        <pre class="code result"><code>{% if status == "ready" %}ビルド準備完了{% elif status == "pending" %}ビルド待機中{% else %}不明な状態{% endif %}</code></pre>
      </div>
    </div>
  </article>

  <article class="demo">
    <h3>for + 配列アクセス</h3>
    <div class="demo-grid">
      <div>
        <h4>ソース</h4>
        <pre class="code"><code>{% raw %}{% for item in features %}
  {{ loop.index }}. {{ item }}
{% endfor %}
先頭: {{ features[0] }}{% endraw %}</code></pre>
      </div>
      <div>
        <h4>結果</h4>
        <pre class="code result"><code>{% for item in features %}{{ loop.index }}. {{ item }}
{% endfor %}先頭: {{ features[0] }}</code></pre>
      </div>
    </div>
  </article>

  <article class="demo">
    <h3>オブジェクトアクセス</h3>
    <div class="demo-grid">
      <div>
        <h4>ソース</h4>
        <pre class="code"><code>{% raw %}{{ build.command }}
{{ build.output }}{% endraw %}</code></pre>
      </div>
      <div>
        <h4>結果</h4>
        <pre class="code result"><code>{{ build.command }}
{{ build.output }}</code></pre>
      </div>
    </div>
  </article>

  <article class="demo">
    <h3>filter + default</h3>
    <div class="demo-grid">
      <div>
        <h4>ソース</h4>
        <pre class="code"><code>{% raw %}{{ frameworkName | upper }}
{{ missingName | default("JSKim") }}{% endraw %}</code></pre>
      </div>
      <div>
        <h4>結果</h4>
        <pre class="code result"><code>{{ frameworkName | upper }}
{{ missingName | default("JSKim") }}</code></pre>
      </div>
    </div>
  </article>

  <article class="demo">
    <h3>rootPath</h3>
    <div class="demo-grid">
      <div>
        <h4>ソース</h4>
        <pre class="code"><code>{% raw %}{{ rootPath }}
{{ rootPath }}assets/css/style.css{% endraw %}</code></pre>
      </div>
      <div>
        <h4>結果</h4>
        <pre class="code result"><code>{{ rootPath }}
{{ rootPath }}assets/css/style.css</code></pre>
      </div>
    </div>
  </article>

  <article class="demo">
    <h3>raw</h3>
    <p>ソースコードブロックは <code>raw</code> で囲み、テンプレートが実行されないように表示します。</p>
    <div class="demo-grid">
      <div>
        <h4>ソース</h4>
        <pre class="code"><code>{{ '{% raw %}' }}
{{ '{{ frameworkName }}' }}
{{ '{% endraw %}' }}</code></pre>
      </div>
      <div>
        <h4>結果（画面に見えるテキスト）</h4>
        <pre class="code result"><code>{% raw %}{{ frameworkName }}{% endraw %}</code></pre>
      </div>
    </div>
  </article>

  <article class="demo">
    <h3>extends / block / include</h3>
    <p>
      このページは <code>layouts/base.njk</code> を <code>extends</code> し、
      layout が <code>components/head.njk</code>、<code>header.njk</code>、<code>footer.njk</code> を
      <code>include</code> します。上部のブランドと下部のフッターがその結果です。
    </p>
  </article>
</section>
{% endblock %}
