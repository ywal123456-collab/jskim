{% extends "layouts/base.njk" %}
{% set currentSection = "portal" %}

{% block title %}Portal - {{ site.name }}{% endblock %}

{% block content %}
<section class="page-intro">
  <p class="eyebrow">公式 sample</p>
  <h1>{{ site.name }}</h1>
  <p class="lead">
    JSKim の files pipeline で画面構成、template 分割、asset 配置を確認できる
    静的 UI sample です。
  </p>
</section>

<section class="notice notice--info" aria-label="静的 UI の案内">
  <h2 class="notice__title">静的 UI sample について</h2>
  <p>
    この sample は、JSKim を使った画面構成、template 分割、asset 配置、
    および build 結果を確認するための静的 UI sample です。
  </p>
  <p>
    API 通信、database、入力検証、登録・更新・削除などの
    application 処理は含まれていません。
  </p>
</section>

<section class="card-grid" aria-label="画面グループ">
  <article class="card">
    <h2 class="card__title">Dashboard</h2>
    <p class="card__body">
      共通 layout、sidebar、summary card、table、notice を確認できます。
    </p>
    <p class="card__actions">
      <a class="button" href="{{ rootPath }}dashboard/index.html">Dashboard を開く</a>
    </p>
  </article>

  <article class="card">
    <h2 class="card__title">CRUD</h2>
    <p class="card__body">
      商品管理の一覧・詳細・登録・編集・削除確認の画面構成例です。
    </p>
    <p class="card__actions">
      <a class="button" href="{{ rootPath }}crud/index.html">CRUD を開く</a>
    </p>
  </article>

  <article class="card">
    <h2 class="card__title">Wizard</h2>
    <p class="card__body">
      入力・確認・完了の 3 ステップ画面構成例です。
    </p>
    <p class="card__actions">
      <a class="button" href="{{ rootPath }}wizard/input.html">Wizard を開く</a>
    </p>
  </article>
</section>
{% endblock %}
