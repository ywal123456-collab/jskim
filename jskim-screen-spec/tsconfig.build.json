{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"]
  },
  "include": [
    "src/index.ts",
    "src/builder/**/*.ts",
    "src/collector/**/*.ts",
    "src/editing/**/*.ts",
    "src/util/**/*.ts",
    "src/watch/**/*.ts"
  ],
  "exclude": [
    "src/viewer/**",
    "test/**",
    "scripts/**"
  ]
}
