{
  "name": "@ywal123456/jskim-screen-spec",
  "version": "0.1.0",
  "private": true,
  "description": "JSKim Screen Spec companion — 画面設計書 viewer build",
  "license": "MIT",
  "author": {
    "name": "Jeongsub Kim",
    "email": "ywal123456@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ywal123456-collab/jskim.git",
    "directory": "jskim-screen-spec"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:sample": "tsx scripts/build-sample.ts",
    "generate:snapshots": "tsx scripts/generate-sample-snapshots.ts",
    "dev:sample": "tsx scripts/build-sample.ts && vite preview --base /spec/",
    "preview:sample": "vite preview --base /spec/",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit || tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9",
    "vue-tsc": "^2.2.8"
  }
}
