{
  "name": "@ywal123456/jskim-screen-spec",
  "version": "0.1.0",
  "private": true,
  "description": "JSKim Screen Spec companion — 画面設計書 viewer build",
  "license": "MIT",
  "author": {
    "name": "Jeongsub Kim",
    "email": "ywal123456@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ywal123456-collab/jskim.git",
    "directory": "jskim-screen-spec"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/viewer",
    "vite.config.ts",
    "index.html",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:sample": "npm run build && tsx scripts/build-sample.ts",
    "generate:snapshots": "tsx scripts/generate-sample-snapshots.ts",
    "dev:sample": "npm run build:sample && vite preview --base /spec/",
    "preview:sample": "vite preview --base /spec/",
    "test": "vitest run --exclude **/collect-integration.test.ts --exclude **/resource-integration.test.ts",
    "test:collector": "vitest run test/collector",
    "test:resources": "vitest run test/resources test/collector/resource-integration.test.ts",
    "install:browsers": "playwright install chromium",
    "typecheck": "vue-tsc --noEmit || tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "playwright": "^1.52.0",
    "postcss": "^8.5.18",
    "postcss-selector-parser": "^7.1.4",
    "postcss-value-parser": "^4.2.0",
    "vite": "^6.2.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "vue-tsc": "^2.2.8"
  }
}
