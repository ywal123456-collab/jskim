{
  "name": "@ywal123456/jskim-screen-spec",
  "version": "0.1.0",
  "description": "JSKim Screen Spec companion — 画面設計書の collect / viewer build",
  "keywords": [
    "jskim",
    "screen-spec",
    "nunjucks",
    "static-html",
    "playwright",
    "vue",
    "vite",
    "documentation"
  ],
  "license": "MIT",
  "author": {
    "name": "Jeongsub Kim",
    "email": "ywal123456@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ywal123456-collab/jskim.git",
    "directory": "jskim-screen-spec"
  },
  "homepage": "https://github.com/ywal123456-collab/jskim/tree/main/jskim-screen-spec#readme",
  "bugs": {
    "url": "https://github.com/ywal123456-collab/jskim/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/viewer",
    "vite.config.ts",
    "index.html",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "peerDependencies": {
    "@ywal123456/jskim": "^0.6.0"
  },
  "peerDependenciesMeta": {
    "@ywal123456/jskim": {
      "optional": false
    }
  },
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.build.json",
    "build:sample": "npm run build && tsx scripts/build-sample.ts",
    "generate:snapshots": "tsx scripts/generate-sample-snapshots.ts",
    "dev:sample": "npm run build:sample && vite preview --base /spec/",
    "preview:sample": "vite preview --base /spec/",
    "test": "vitest run --exclude **/collect-integration.test.ts --exclude **/resource-integration.test.ts --exclude **/device-capture/collect-integration.test.ts",
    "test:collector": "vitest run test/collector",
    "test:resources": "vitest run test/resources test/collector/resource-integration.test.ts",
    "test:watch": "vitest run test/watch",
    "test:editing": "vitest run test/editing",
    "test:design-first": "vitest run test/builder test/editing test/viewer test/screen-page-router.test.ts",
    "test:item-exclusion-ui": "vitest run test/editing/exclude-description-item.test.ts test/viewer/exclude-item-dialog.test.ts test/viewer/excluded-items-panel.test.ts test/item-description-table.test.ts test/dom-preview.test.ts test/viewer/screen-spec-page.test.ts test/editing/viewer-editing.test.ts",
    "test:screen-duplicate": "vitest run test/editing/suggest-copy-screen-id.test.ts test/viewer/duplicate-screen-dialog.test.ts test/editing/file-description-store.test.ts test/viewer/screen-spec-page.test.ts",
    "test:implementation-only": "vitest run test/collector/write-collected-description.test.ts test/builder/load-screen-spec-project.test.ts test/editing/file-description-store.test.ts",
    "test:screen-delete-api": "vitest run test/editing/file-description-delete.test.ts test/editing/description-concurrency.test.ts",
    "test:screen-delete-ui": "vitest run test/viewer/resolve-delete-screen-fallback.test.ts test/viewer/delete-screen-dialog.test.ts test/editing/pending-screen.test.ts test/viewer/screen-spec-page.test.ts",
    "test:device-capture-core": "vitest run test/device-capture",
    "test:device-capture-api": "vitest run test/device-capture/manifest-captures.test.ts test/watch/classify-watch-path.test.ts",
    "install:browsers": "playwright install chromium",
    "typecheck": "vue-tsc --noEmit || tsc --noEmit",
    "release:check": "npm run build && npm test && npm run test:collector && npm run test:resources && npm run test:watch"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "playwright": "^1.52.0",
    "postcss": "^8.5.18",
    "postcss-selector-parser": "^7.1.4",
    "postcss-value-parser": "^4.2.0",
    "vite": "^6.2.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "vue-tsc": "^2.2.8"
  }
}
